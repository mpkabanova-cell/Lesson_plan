# OpenRouter API key (server only — never expose to the browser).
# Paste the key as-is (no "quotes"). On Render: Environment → add OPENROUTER_API_KEY.
OPENROUTER_API_KEY=

# Model id, e.g. openai/gpt-4o-mini
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional: shown in OpenRouter dashboard
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Конструктор плана урока

# Max characters for lesson plan editor body (WYSIWYG)
NEXT_PUBLIC_PLAN_CONTENT_MAX_CHARS=100000

# Optional: trim methodology file (konstruktorUroka.md) when building the system prompt (server only)
# LESSON_METHODOLOGY_MAX_CHARS=120000

# Optional: trim subject-specific knowledge (e.g. informatika_7_9.md for Informatics grades 7–9) (server only)
# LESSON_SUBJECT_KNOWLEDGE_MAX_CHARS=120000

# Google Programmable Search Engine (Custom Search JSON API) — только для вкладки «Поиск материалов» (1sept.ru).
# Настройка: см. раздел README «Поиск материалов (1sept.ru)».
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# Google Custom Search JSON API — только для вкладки «Поиск материалов» (POST /api/search-1sept). Сервер only.
# См. README: Programmable Search Engine (cx) + API key в Google Cloud.
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
